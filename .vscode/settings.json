{
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports.biome": "explicit",
    "source.fixAll.biome": "always"
  },
  "cSpell.words": [
    "codegen",
    "dotenv",
    "healthz",
    "kysely",
    "multistream",
    "readyz",
    "timestamptz",
    "typebox",
    "usecases"
  ],
  "yaml.schemas": {
    "https://www.artillery.io/schema.json": []
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  }
}
